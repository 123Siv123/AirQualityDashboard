# Gas bands (MQ-2 typical clean air ~150-220)
# Safe: gas <= GAS_SAFE_MAX
# Moderate: GAS_MODERATE .. GAS_MODERATE_MAX
# Poor / smoke voice: gas >= GAS_CRITICAL

GAS_SENSOR=standard
GAS_SAFE_MAX=240
GAS_MODERATE=241
GAS_MODERATE_MAX=280
GAS_CRITICAL=281

# High-baseline MQ-2 (if clean air reads 400+):
# GAS_SENSOR=mq2

# --- Twilio SMS (https://www.twilio.com) ---
# Copy this file to .env and fill in your values. Install: pip install -r requirements.txt
TWILIO_ENABLED=1
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1234567890
TWILIO_TO_NUMBER=+1987654321
# Optional: multiple numbers comma-separated
# TWILIO_ALERT_NUMBERS=+1987654321,+15551234567
TWILIO_SMS_COOLDOWN_SEC=300
# SMS on moderate band too (default: critical/poor only)
# TWILIO_SMS_MODERATE=1
# Allow POST http://127.0.0.1:5000/api/sms/test for a test message
# TWILIO_ALLOW_TEST=1

# Debug endpoint (do NOT enable in production)
# Allows POST http://127.0.0.1:5000/api/debug/set_gas with {"gas": 300}
# DEBUG_ALLOW_SET_GAS=1

# Keep smoke alert active for a short time (so UI can beep/voice even if spike drops quickly)
SMOKE_LATCH_SEC=60
